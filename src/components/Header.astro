---
const nav = [
  { href: '/', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? currentPath === href : currentPath.startsWith(href);
---

<header class="border-b border-border">
  <nav class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" id="site-title" class="text-text font-semibold text-lg no-underline hover:text-accent transition-colors">
      lukebatchelor.net
    </a>
    <ul class="flex gap-6 list-none m-0 p-0">
      {nav.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-sm no-underline transition-colors',
              isActive(href)
                ? 'text-accent'
                : 'text-text-muted hover:text-text',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  if (window.location.hostname === 'lbatch.com') {
    document.getElementById('site-title')!.textContent = 'lbatch.com';
  }
</script>
